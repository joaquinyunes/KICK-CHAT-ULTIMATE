# StreamChat Bridge - Variables de Entorno
# Copiar a .env y NUNCA commitear .env

# Clave maestra AES-256 (exactamente 32 caracteres)
MASTER_KEY=cambia_esta_clave_a_exactamente_32!

# Secreto JWT (minimo 32 caracteres)
JWT_SECRET=un_secreto_muy_largo_y_aleatorio_para_jwt_cambiame

# Puerto del servidor
PORT=3000

# Entorno (development o production)
NODE_ENV=development

# URL del endpoint de Kick
KICK_API_URL=https://kick.com/api/v2/messages/send

# Duracion del JWT
JWT_EXPIRES_IN=24h

# Secreto admin para acceder a /status/metrics (telemetria)
ADMIN_SECRET=cambia_este_secreto_por_uno_seguro
